#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <sys/wait.h>

#define MAX_ARGS 128

int main(int argc, char *argv[]) {
    for (int i = 1; i < argc; i++) {
        int fd[2];

        if (pipe(fd) == -1) {
            perror("pipe");
            return 1;
        }

        pid_t command_pid = fork();

        if (command_pid == -1) {
            perror("fork");
            return 1;
        }

        if (command_pid == 0) {
            close(fd[0]);
            dup2(fd[1], STDOUT_FILENO);
            close(fd[1]);

            char *command_copy = strdup(argv[i]);
            if (command_copy == NULL) {
                perror("strdup");
                exit(1);
            }

            char *args[MAX_ARGS];
            int count = 0;

            char *token = strtok(command_copy, " \t");
            while (token != NULL && count < MAX_ARGS - 1) {
                args[count++] = token;
                token = strtok(NULL, " \t");
            }
            args[count] = NULL;

            if (args[0] == NULL) {
                free(command_copy);
                exit(1);
            }

            execvp(args[0], args);
            perror("execvp");
            free(command_copy);
            exit(1);
        }

        pid_t wc_pid = fork();

        if (wc_pid == -1) {
            perror("fork");
            return 1;
        }

        if (wc_pid == 0) {
            close(fd[1]);
            dup2(fd[0], STDIN_FILENO);
            close(fd[0]);

            execlp("wc", "wc", "-c", NULL);
            perror("execlp");
            exit(1);
        }

        close(fd[0]);
        close(fd[1]);

        waitpid(command_pid, NULL, 0);
        waitpid(wc_pid, NULL, 0);
    }

    return 0;
}
